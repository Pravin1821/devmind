# ─────────────────────────────────────────
# codepi — AI Provider Configuration
# ─────────────────────────────────────────

# RECOMMENDED: NVIDIA Free API
# Get free key at: build.nvidia.com
# NVIDIA_API_KEY=your_nvidia_key_here

# Optional: Force a specific provider
# Values: nvidia, openai, anthropic, ollama
# AI_PROVIDER=nvidia

# Optional: Override model
# AI_MODEL=meta/llama-3.1-8b-instruct

# Optional: Anthropic Claude
# ANTHROPIC_API_KEY=your_key_here

# Optional: OpenAI
# OPENAI_API_KEY=your_key_here

# API Key (fallback for nvidia/openai/anthropic if provider-specific key not set)
# AI_API_KEY=

# Custom base URL (optional, for OpenAI-compatible endpoints)
# AI_BASE_URL=

# Request timeout in milliseconds (default: 300000 = 5 min)
# AI_TIMEOUT=300000

# ─────────────────────────────────────────
# Ollama (Local AI — no API key needed)
# Install: ollama.com
# Run: ollama pull llama3.2
# codepi auto-detects if Ollama is running
# ─────────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
