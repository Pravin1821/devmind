# ── AI Provider ──────────────────────────────────
# Choose: openai | nvidia | anthropic | ollama (default)
AI_PROVIDER=ollama

# Model per provider:
#   openai:    gpt-4o, gpt-4o-mini
#   nvidia:    meta/llama-3.1-8b-instruct, meta/llama-3.3-70b-instruct, nvidia/llama-3.3-nemotron-super-49b-v1
#   anthropic: claude-sonnet-4-20250514, claude-3-5-haiku-latest
#   ollama:    llama3.2, llama3.1
AI_MODEL=llama3.2

# API Key (required for openai, nvidia, anthropic).
# Falls back to OPENAI_API_KEY or ANTHROPIC_API_KEY if not set.
AI_API_KEY=

# Custom base URL (optional, for OpenAI-compatible endpoints)
# NVIDIA default: https://integrate.api.nvidia.com/v1
AI_BASE_URL=

# Request timeout in milliseconds (default: 300000 = 5 min)
AI_TIMEOUT=300000

# ── Fallback API Keys ──────────────────────────
# These are read automatically if AI_API_KEY is not set.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Ollama (only used when AI_PROVIDER=ollama) ──
OLLAMA_URL=http://localhost:11434
